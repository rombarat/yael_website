---
const photos = [
  "/images/IMG_2885.jpg",
  "/images/IMG_2960.jpg",
  "/images/IMG_3182.jpg",
  "/images/IMG_4229.jpg",
  "/images/IMG_4498.jpg",
  "/images/IMG_4702.jpg",
  "/images/IMG_6169.jpg",
  "/images/IMG_6891.jpg",
  "/images/IMG_7946.jpg",
];
const heights = ["aspect-[3/4]", "aspect-[4/5]", "aspect-square", "aspect-[4/5]", "aspect-[3/4]", "aspect-square", "aspect-[4/5]", "aspect-[3/4]", "aspect-[4/5]"];
const tilts = [-1, 1, -0.5, 1, -1, 0.5, -1, 1, -0.5];
---
<section class="py-24 sm:py-36 px-6 sm:px-10 lg:px-14 bg-[var(--color-bg)] relative overflow-hidden">
  <div class="max-w-7xl mx-auto relative">
    <header class="reveal mb-14 sm:mb-20 text-center">
      <span class="ltr inline-block bg-[var(--color-coral)] text-[var(--color-soft)] text-xs tracking-[0.3em] uppercase font-bold px-4 py-2 rounded-full mb-5">
        ★ Gallery
      </span>
      <h2 class="font-display text-4xl sm:text-5xl lg:text-6xl leading-[1.1] text-[var(--color-ink)]">
        קצת <span class="relative inline-block text-[var(--color-coral)]">וייבים<svg viewBox="0 0 180 14" class="absolute -bottom-3 right-0 w-full h-4" preserveAspectRatio="none" aria-hidden="true"><path d="M2 9 Q 45 2, 90 8 T 178 7" stroke="#FFC93C" stroke-width="5" fill="none" stroke-linecap="round"/></svg></span> מהשטח.
      </h2>
      <p class="mt-6 text-[var(--color-muted)] text-base sm:text-lg max-w-xl mx-auto">
        כי תמונה שווה אלף מילים, אבל להיות שם שווה הרבה יותר. הנה קצת ממה שקרה אצלנו לאחרונה:
      </p>
    </header>

    <div class="columns-2 md:columns-3 gap-4 sm:gap-6 [column-fill:_balance]">
      {photos.map((src, i) => (
        <div
          class={`reveal-scale img-card mb-4 sm:mb-6 break-inside-avoid rounded-3xl overflow-hidden shadow-[0_20px_40px_-15px_rgba(31,20,16,0.2)] ${heights[i % heights.length]}`}
          style={`transform: rotate(${tilts[i]}deg);`}
        >
          <img src={src} alt="" loading="lazy" class="w-full h-full object-cover" />
        </div>
      ))}
    </div>
  </div>
</section>
