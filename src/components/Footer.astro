  <div class="max-w-7xl mx-auto flex flex-col items-center gap-6 text-center">
    <div class="font-display text-3xl sm:text-4xl text-[var(--color-coral)]">
      תל אביב · צעירים · ביחד
    </div>

    <div class="flex items-center gap-6 ltr text-sm tracking-[0.25em] font-bold">
      <a href="https://www.instagram.com/yael_pinchas_israel" target="_blank" rel="noopener"
         class="hover:text-[var(--color-coral)] transition">INSTAGRAM</a>
      <span class="opacity-40">|</span>
      <a href="https://wa.me/972549899305" target="_blank" rel="noopener"
         class="hover:text-[var(--color-coral)] transition">WHATSAPP</a>
    </div>

    <a href="tel:+972549899305" class="ltr text-base text-[var(--color-soft)]/80 hover:text-[var(--color-sunshine)] transition tabular">
      054-989-9305
