  <div class="max-w-7xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-8 items-center">
    <div class="ltr text-xs tracking-[0.3em] uppercase opacity-70">
      © {year} TLV Young Community
    </div>

    <div class="text-center font-display text-2xl">
      תל אביב · צעירים · ביחד
    </div>

    <div class="flex items-center sm:justify-end gap-5 text-xs ltr tracking-widest opacity-70">
      <a href="https://www.instagram.com/yael_pinchas_israel" target="_blank" rel="noopener" class="hover:text-[var(--color-coral)] transition">INSTAGRAM</a>
      <span class="opacity-50">·</span>
      <a href="https://wa.me/972549899305" target="_blank" rel="noopener" class="hover:text-[var(--color-coral)] transition">WHATSAPP</a>
    </div>
