---
const wa = "https://wa.me/972549899305?text=" + encodeURIComponent("היי, ראיתי את האתר ואני רוצה להצטרף ל-TLV Young");
const ig = "https://www.instagram.com/yael_pinchas_israel";
const tel = "tel:+972549899305";
---
<section id="join" class="bg-[var(--color-ocean)] text-[var(--color-soft)] py-28 sm:py-44 px-6 sm:px-10 lg:px-14 relative overflow-hidden">
  <!-- Decorative blobs -->
  <div class="absolute -top-32 -left-32 w-[600px] h-[600px] rounded-full bg-[var(--color-coral)]/25 blur-3xl pointer-events-none"></div>
  <div class="absolute -bottom-40 -right-32 w-[500px] h-[500px] rounded-full bg-[var(--color-sunshine)]/20 blur-3xl pointer-events-none"></div>

  <div class="max-w-4xl mx-auto relative z-10 text-center reveal">
    <span class="ltr inline-block bg-[var(--color-coral)] text-[var(--color-soft)] text-xs tracking-[0.3em] uppercase font-bold px-4 py-2 rounded-full mb-6">
      ★ Join the Community
    </span>
    <h2 class="font-display text-5xl sm:text-7xl lg:text-[7rem] leading-[0.95]">
      אז...<br/>
      <span class="relative inline-block text-[var(--color-sunshine)]">באים?<svg viewBox="0 0 200 14" class="absolute -bottom-3 right-0 w-full h-4" preserveAspectRatio="none" aria-hidden="true"><path d="M2 9 Q 50 2, 100 8 T 198 7" stroke="#FF5841" stroke-width="6" fill="none" stroke-linecap="round"/></svg></span>
    </h2>
    <p class="mt-10 text-[var(--color-soft)]/85 text-lg sm:text-xl max-w-2xl mx-auto leading-relaxed">
      תעשו את הצעד הראשון, אנחנו נדאג לכל השאר.
      שלחו לנו הודעה בוואטסאפ <span class="opacity-80">(אנחנו עונים מהר, מבטיחים)</span> וקבלו עדכונים על המפגש הבא שלנו בעיר.
      <span class="block mt-2 font-bold text-[var(--color-sunshine)]">מחכים להכיר!</span>
    </p>

    <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-5">
      <a
        href={wa}
        target="_blank"
        rel="noopener"
        class="btn-pill btn-pill-lg"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        <span>שלחו לנו וואטסאפ</span>
      </a>

      <div class="flex items-center gap-3">
        <a href={ig} target="_blank" rel="noopener" aria-label="Instagram"
           class="btn-outline text-[var(--color-soft)] hover:bg-[var(--color-soft)] hover:text-[var(--color-ocean)]">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
          </svg>
          <span class="text-sm">Instagram</span>
        </a>
        <a href={tel} aria-label="Phone"
           class="btn-outline text-[var(--color-soft)] hover:bg-[var(--color-soft)] hover:text-[var(--color-ocean)]">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          <span class="text-sm ltr">054-989-9305</span>
        </a>
      </div>
    </div>
  </div>
</section>
