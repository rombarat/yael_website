---
import Stickers from "./Stickers.astro";
const wa = "https://wa.me/972549899305?text=" + encodeURIComponent("היי, ראיתי את האתר ואני רוצה להצטרף ל-TLV Young");
const ig = "https://www.instagram.com/yael_pinchas_israel";
const tel = "tel:+972549899305";
---
<section id="join" class="bg-[var(--color-ocean)] text-[var(--color-soft)] py-28 sm:py-44 px-6 sm:px-10 lg:px-14 relative overflow-hidden">
  <!-- Decorative blobs -->
  <div class="absolute -top-32 -left-32 w-[600px] h-[600px] rounded-full bg-[var(--color-coral)]/25 blur-3xl pointer-events-none"></div>
  <div class="absolute -bottom-40 -right-32 w-[500px] h-[500px] rounded-full bg-[var(--color-sunshine)]/20 blur-3xl pointer-events-none"></div>

  <!-- Stickers -->
  <div class="absolute top-16 right-[10%]" data-sticker="0.08">
    <Stickers variant="sun" class="w-20 h-20 sm:w-28 sm:h-28 text-[var(--color-sunshine)]" />
  </div>
  <div class="hidden md:block absolute bottom-20 left-[8%]" data-sticker="-0.06">
    <Stickers variant="spark" class="w-14 h-14 text-[var(--color-coral)]" />
  </div>

  <div class="max-w-4xl mx-auto relative z-10 text-center reveal">
    <span class="ltr inline-block bg-[var(--color-coral)] text-[var(--color-soft)] text-xs tracking-[0.3em] uppercase font-bold px-4 py-2 rounded-full mb-6">
      ★ Join the Community
    </span>
    <h2 class="font-display text-5xl sm:text-7xl lg:text-[7rem] leading-[0.95]">
      יאללה,<br/>
      <span class="relative inline-block text-[var(--color-sunshine)]">נכנסים?<svg viewBox="0 0 240 14" class="absolute -bottom-3 left-0 w-full h-4" preserveAspectRatio="none"><path d="M2 9 Q 60 2, 120 8 T 238 7" stroke="#FF5841" stroke-width="6" fill="none" stroke-linecap="round"/></svg></span>
    </h2>
    <p class="mt-10 text-[var(--color-soft)]/85 text-lg sm:text-xl max-w-2xl mx-auto leading-relaxed">
      שלחו לנו הודעה בוואטסאפ ותתחילו לקבל עדכונים
      על האירועים הבאים וההתארגנויות שלנו בעיר.
    </p>

    <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-5">
      <a
        href={wa}
        target="_blank"
        rel="noopener"
        class="btn-pill btn-pill-lg"
      >
        <span class="text-2xl">💬</span>
        <span>שלחו וואטסאפ</span>
      </a>

      <div class="flex items-center gap-3">
        <a href={ig} target="_blank" rel="noopener" aria-label="Instagram"
           class="btn-outline text-[var(--color-soft)] hover:bg-[var(--color-soft)] hover:text-[var(--color-ocean)]">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
          </svg>
          <span class="text-sm">Instagram</span>
        </a>
        <a href={tel} aria-label="Phone"
           class="btn-outline text-[var(--color-soft)] hover:bg-[var(--color-soft)] hover:text-[var(--color-ocean)]">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          <span class="text-sm ltr">054-989-9305</span>
        </a>
      </div>
    </div>
  </div>
</section>
