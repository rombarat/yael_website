---
const items = [
  { num: "01", title: "מסיבות", desc: "ערבי יציאה, דאנס פלורים ומסיבות קונספט", img: "/images/IMG_2299.jpg" },
  { num: "02", title: "מפגשים חברתיים", desc: "ארוחות, פגישות אחרי העבודה והיכרויות", img: "/images/IMG_3937.jpg" },
  { num: "03", title: "ספורט", desc: "ריצות, יוגה, בוקר חוף ואימוני קבוצה", img: "/images/IMG_6383.jpg" },
  { num: "04", title: "אירועי תוכן", desc: "הרצאות, סדנאות וערבי שיח", img: "/images/IMG_2388.jpg" },
];
---
<section class="py-24 sm:py-36 px-6 sm:px-10 lg:px-14 bg-[var(--color-soft)]">
  <div class="max-w-7xl mx-auto">
    <header class="reveal mb-14 sm:mb-20 flex items-end justify-between gap-6 flex-wrap">
      <div>
        <div class="ltr text-[11px] tracking-[0.3em] uppercase text-[var(--color-coral)] font-medium mb-3">— What We Do</div>
        <h2 class="font-display font-bold text-4xl sm:text-6xl lg:text-7xl leading-[1] text-[var(--color-ink)]">
          ארבע דרכים<br/>להתחבר.
        </h2>
      </div>
      <div class="font-poster text-[var(--color-coral)] text-5xl sm:text-7xl leading-none opacity-90">03</div>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-14 sm:gap-y-20">
      {items.map((item, i) => (
        <article class={`reveal ${i % 2 === 1 ? "md:mt-16" : ""}`}>
          <div class="img-hover rounded-sm overflow-hidden bg-[var(--color-bg)] aspect-[4/5]">
            <img
              src={item.img}
              alt={item.title}
              loading="lazy"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="mt-5 flex items-baseline gap-4">
            <span class="font-poster text-[var(--color-coral)] text-3xl sm:text-4xl tabular">{item.num}</span>
            <span class="h-px flex-1 bg-[var(--color-border)] mb-2"></span>
          </div>
          <h3 class="mt-3 font-display font-bold text-3xl sm:text-4xl text-[var(--color-ink)]">{item.title}</h3>
          <p class="mt-2 text-[var(--color-muted)] text-base sm:text-lg leading-relaxed">{item.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>
