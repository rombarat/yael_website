---
const items = [
  { num: "01", title: "מרימים הילוך: מסיבות וחיי לילה", desc: "מסיבות גג סגורות, יציאות משותפות לקלאבים ודאנס-פלורים באווירה שמרגישה כמו מסיבת בית אחת גדולה.", img: "/images/IMG_6383.jpg", accent: "coral" },
  { num: "02", title: "מורידים הילוך: מפגשים ספונטניים", desc: "כוס יין אחרי העבודה, ארוחות ערב משותפות או סתם ישיבה על ספסל בשדרה. פשוט כדי לדבר ולהכיר בלי פילטרים.", img: "/images/IMG_3937.jpg", accent: "sunshine" },
  { num: "03", title: "זזים ביחד: כושר וספורט", desc: "קבוצות ריצה בפארק, אימוני כוח על החוף ויוגה מול השקיעה. הדרך הכי טובה להזיע עם חיוך ועם אנשים טובים.", img: "/images/IMG_2299.jpg", accent: "ocean" },
  { num: "04", title: "פותחים את הראש: תוכן והשראה", desc: "הרצאות על הבר, סדנאות מיוחדות וערבים שנותנים קצת ערך מוסף מעבר לדרינק.", img: "/images/IMG_2388.jpg", accent: "pink" },
];
const accentMap: Record<string, string> = {
  coral: "var(--color-coral)",
  sunshine: "var(--color-sunshine)",
  ocean: "var(--color-ocean)",
  pink: "var(--color-pink)",
};
const blobs = ["blob-1", "blob-2", "blob-3", "blob-1"];
---
<section class="py-24 sm:py-36 px-6 sm:px-10 lg:px-14 bg-[var(--color-soft)] relative overflow-hidden">
  <div class="max-w-7xl mx-auto relative">
    <header class="reveal mb-14 sm:mb-20 text-center">
      <span class="ltr inline-block bg-[var(--color-sunshine)] text-[var(--color-ink)] text-xs tracking-[0.3em] uppercase font-bold px-4 py-2 rounded-full mb-5">
        ★ What We Do
      </span>
      <h2 class="font-display text-4xl sm:text-5xl lg:text-6xl leading-[1.1] text-[var(--color-ink)] max-w-3xl mx-auto">
        אז מה עושים תכל'ס?<br/>
        הנה <span class="text-[var(--color-coral)]">4 תירוצים מעולים</span> שלנו להיפגש:
      </h2>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-16 sm:gap-y-24">
      {items.map((item, i) => (
        <article class={`reveal ${i % 2 === 1 ? "md:mt-20" : ""}`}>
          <div class={`relative img-card ${blobs[i]} aspect-[4/5] shadow-[0_30px_60px_-20px_rgba(31,20,16,0.25)]`}>
            <img
              src={item.img}
              alt={item.title}
              loading="lazy"
              class="w-full h-full object-cover"
            />
            <span
              class="absolute top-5 right-5 inline-flex items-center justify-center w-16 h-16 sm:w-20 sm:h-20 rounded-full font-display text-2xl sm:text-3xl tabular text-[var(--color-ink)] shadow-lg"
              style={`background: ${accentMap[item.accent]}`}
            >
              {item.num}
            </span>
          </div>
          <h3 class="mt-6 font-display text-3xl sm:text-4xl text-[var(--color-ink)]">{item.title}</h3>
          <p class="mt-3 text-[var(--color-muted)] text-base sm:text-lg leading-relaxed">{item.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>
